# ========================================
# 数据库配置
# ========================================

# PostgreSQL 数据库连接字符串
DATABASE_URL="postgresql://nexus:nexus123@localhost:5432/nexus_chat"

# ========================================
# NextAuth.js 配置
# ========================================

# 应用 URL（开发环境）
NEXTAUTH_URL="http://localhost:3000"

# 会话密钥（生产环境请使用至少 32 字符的随机字符串）
# 生成方式: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-change-in-production-min-32-chars"

# ========================================
# Socket.io 配置
# ========================================

# Socket.io 服务器地址
# 开发环境: http://localhost:3002 (Docker 映射端口)
# 生产环境: 改为实际的域名，如 https://your-domain.com:3002
NEXT_PUBLIC_SOCKET_URL="http://localhost:3002"

# ========================================
# AI 提供商 API Key 配置
# ========================================

# 阿里云通义千问（推荐，免费额度充足）
# 获取地址: https://modelstudio.console.alibabacloud.com/
# 免费额度: 新用户千万 tokens，主流模型各 100 万 tokens
ALIBABA_API_KEY=your_alibaba_api_key_here

# DeepSeek（备选，推理能力强）
# 获取地址: https://platform.deepseek.com/
# 免费额度: 普通用户在线使用免费
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 智谱清言（备选，GLM-4-Flash 免费）
# 获取地址: https://open.bigmodel.cn/
# 免费额度: GLM-4-Flash 推理 API 完全免费
ZHIPU_API_KEY=your_zhipu_api_key_here

# OpenAI（降级备选，付费）
# 获取地址: https://platform.openai.com/
# 价格: GPT-4 Turbo 约 $0.01-0.02/次
OPENAI_API_KEY=your_openai_api_key_here

# ========================================
# AI 模型配置
# ========================================

# 默认使用的提供商
# 可选值: alibaba, deepseek, zhipu, openai
AI_PROVIDER=alibaba

# 默认模型名称
# 通义千问: qwen-plus, qwen-turbo
# DeepSeek: deepseek-chat, deepseek-v3
# 智谱清言: glm-4-flash
# OpenAI: gpt-4-turbo-preview
AI_MODEL=qwen-plus

# 建议数量（1-3）
AI_SUGGESTION_COUNT=3

# 每日使用限制（次/用户）
AI_DAILY_LIMIT=20

# ========================================
# AI API 配置
# ========================================

# API 超时时间（毫秒）
AI_TIMEOUT=30000

# 最大重试次数
AI_MAX_RETRIES=2

# ========================================
# Redis 配置（可选）
# ========================================

# Redis 连接字符串（用于缓存和频率限制）
# 如果不配置，将使用内存存储（仅限开发环境）
REDIS_URL=redis://localhost:6379

# Upstash Redis（Serverless 环境推荐）
# UPSTASH_REDIS_REST_URL=your_upstash_url
# UPSTASH_REDIS_REST_TOKEN=your_upstash_token
